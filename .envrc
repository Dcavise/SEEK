# Primer Seek Property Development Environment Configuration
# This file is used by direnv to automatically set up the development environment
# when entering the project directory.

# ==============================================
# PROJECT INFORMATION
# ==============================================
export PROJECT_NAME="primer-seek-property"
export PROJECT_VERSION="1.0.0"
export NODE_ENV="development"
export ENVIRONMENT="development"

# ==============================================
# PYTHON CONFIGURATION
# ==============================================
# Pin Python version as specified in plan.md (3.12.x)
export PYTHON_VERSION="3.12.7"

# Add Poetry to PATH if installed
if command -v poetry &> /dev/null; then
    export POETRY_ACTIVE=1
    export POETRY_VENV_IN_PROJECT=1
    export POETRY_CACHE_DIR="$PWD/.poetry-cache"
fi

# ==============================================
# NODE.JS / PNPM CONFIGURATION
# ==============================================
# Pin Node.js and pnpm versions as specified in plan.md
export NODE_VERSION="20.17.0"
export PNPM_VERSION="8.15.8"

# pnpm configuration
export PNPM_HOME="$HOME/.local/share/pnpm"
export PNPM_CACHE_DIR="$PWD/.pnpm-cache"

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# Supabase configuration (placeholders - replace with actual values)
export SUPABASE_URL="https://your-project-ref.supabase.co"
export SUPABASE_ANON_KEY="your-anon-key-here"
export SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Database connection strings
export DATABASE_URL="postgresql://postgres:password@localhost:54322/postgres"  # pragma: allowlist secret
export DATABASE_URL_DIRECT="postgresql://postgres:password@localhost:54322/postgres"

# PostGIS extension support
export POSTGIS_ENABLED="true"

# ==============================================
# REDIS CONFIGURATION
# ==============================================
# Redis connection (placeholder - replace with actual values)
export REDIS_URL="redis://localhost:6379"
export REDIS_PASSWORD=""
export REDIS_DB="0"

# ==============================================
# API CONFIGURATION
# ==============================================
# Backend API configuration
export API_BASE_URL="http://localhost:8000"
export API_VERSION="v1"
export API_TIMEOUT="30000"

# CORS configuration for development
export CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ==============================================
# AUTHENTICATION CONFIGURATION
# ==============================================
# JWT configuration
export JWT_SECRET="your-development-jwt-secret-here"  # pragma: allowlist secret
export JWT_ALGORITHM="HS256"
export JWT_EXPIRE_MINUTES="720"

# Session configuration
export SESSION_SECRET="your-development-session-secret-here"  # pragma: allowlist secret
export SESSION_EXPIRE_HOURS="24"

# ==============================================
# EXTERNAL SERVICES CONFIGURATION
# ==============================================
# Mapbox configuration (placeholder - replace with actual values)
export MAPBOX_ACCESS_TOKEN="pk.your-mapbox-token-here"
export MAPBOX_STYLE_URL="mapbox://styles/mapbox/streets-v12"

# Third-party integrations (future)
export SALESFORCE_CLIENT_ID=""
export SALESFORCE_CLIENT_SECRET=""

# ==============================================
# DEVELOPMENT TOOLS CONFIGURATION
# ==============================================
# Logging configuration
export LOG_LEVEL="DEBUG"
export LOG_FORMAT="structured"
export LOG_FILE="logs/development.log"

# Performance monitoring
export ENABLE_PROFILING="true"
export ENABLE_METRICS="true"

# Development features
export HOT_RELOAD="true"
export AUTO_RELOAD="true"
export DEBUG_MODE="true"

# Testing configuration
export TEST_DATABASE_URL="postgresql://postgres:password@localhost:54322/test_db"
export PYTEST_DISABLE_PLUGIN_AUTOLOAD="1"

# ==============================================
# FILE STORAGE CONFIGURATION
# ==============================================
# Local file storage for development
export STORAGE_PATH="./storage"
export UPLOAD_MAX_SIZE="100MB"
export ALLOWED_FILE_TYPES="csv,xlsx,json"

# ==============================================
# RATE LIMITING CONFIGURATION
# ==============================================
export RATE_LIMIT_ENABLED="false"
export RATE_LIMIT_REQUESTS="1000"
export RATE_LIMIT_WINDOW="3600"

# ==============================================
# PATH CONFIGURATION
# ==============================================
# Add project-specific binaries to PATH
export PATH="$PWD/scripts:$PATH"
export PATH="$PWD/backend/.venv/bin:$PATH"
export PATH="$PWD/frontend/node_modules/.bin:$PATH"
export PATH="$PNPM_HOME:$PATH"

# Add Poetry to PATH if not already present
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# ==============================================
# DEVELOPMENT ALIASES AND FUNCTIONS
# ==============================================
# Backend development aliases
alias backend-dev="cd backend && poetry run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000"
alias backend-test="cd backend && poetry run pytest -v"
alias backend-shell="cd backend && poetry shell"
alias backend-install="cd backend && poetry install"

# Frontend development aliases
alias frontend-dev="cd frontend && pnpm dev"
alias frontend-build="cd frontend && pnpm build"
alias frontend-test="cd frontend && pnpm test"
alias frontend-install="cd frontend && pnpm install"

# Database management aliases
alias db-migrate="cd backend && poetry run alembic upgrade head"
alias db-reset="cd backend && poetry run alembic downgrade base && poetry run alembic upgrade head"
alias db-shell="psql $DATABASE_URL"

# Project management aliases
alias setup-all="backend-install && frontend-install"
alias test-all="backend-test && frontend-test"
alias lint-all="cd backend && poetry run ruff check . && cd ../frontend && pnpm lint"
alias format-all="cd backend && poetry run black . && poetry run ruff format . && cd ../frontend && pnpm format"

# ==============================================
# ENVIRONMENT VALIDATION
# ==============================================
# Check if required tools are installed
check_tool() {
    if ! command -v "$1" &> /dev/null; then
        echo "Warning: $1 is not installed or not in PATH"
    fi
}

# Validate development environment
validate_environment() {
    echo "🔍 Validating development environment..."
    check_tool "python3"
    check_tool "poetry"
    check_tool "node"
    check_tool "pnpm"
    check_tool "psql"
    check_tool "redis-cli"
    echo "✅ Environment validation complete"
}

# ==============================================
# DIRENV HOOKS
# ==============================================
# Display environment info when entering directory
echo "🏗️  Primer Seek Property Development Environment"
echo "📁 Project: $PROJECT_NAME v$PROJECT_VERSION"
echo "🐍 Python: $PYTHON_VERSION"
echo "📦 Node.js: $NODE_VERSION | pnpm: $PNPM_VERSION"
echo "🗄️  Database: $(echo $DATABASE_URL | sed 's/:.*/.../')"
echo "🔴 Redis: $(echo $REDIS_URL | sed 's/:.*/.../')"
echo ""
echo "💡 Available aliases:"
echo "   • backend-dev    - Start backend development server"
echo "   • frontend-dev   - Start frontend development server"
echo "   • setup-all      - Install all dependencies"
echo "   • test-all       - Run all tests"
echo "   • lint-all       - Run all linters"
echo "   • format-all     - Format all code"
echo ""

# Optional: Run validation on environment load
# validate_environment
