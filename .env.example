# Primer Seek Property Environment Variables Example
# Copy this file to .env and fill in the actual values for your environment
#
# IMPORTANT: Never commit actual environment variables to version control!
# This file serves as documentation for required environment variables.

# ==============================================
# PROJECT CONFIGURATION
# ==============================================
PROJECT_NAME=primer-seek-property
PROJECT_VERSION=1.0.0
NODE_ENV=development
ENVIRONMENT=development

# ==============================================
# DATABASE CONFIGURATION (Supabase)
# ==============================================
# Your Supabase project URL (found in Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous key (safe for client-side use)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (server-side only - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct database connection string (for migrations and admin tasks)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL_DIRECT=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Test database (separate instance for testing)
TEST_DATABASE_URL=postgresql://postgres:[password]@db.[test-project-ref].supabase.co:5432/postgres

# PostGIS extension support
POSTGIS_ENABLED=true

# ==============================================
# REDIS CONFIGURATION
# ==============================================
# Redis connection URL (for caching and sessions)
REDIS_URL=redis://default:[password]@[host]:[port]

# Alternative Redis configuration
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0

# Redis cluster configuration (production)
# REDIS_CLUSTER_NODES=redis1:6379,redis2:6379,redis3:6379

# ==============================================
# AUTHENTICATION & SECURITY
# ==============================================
# JWT secret for token signing (generate a strong random string!)
JWT_SECRET=your-super-secret-jwt-key-here-minimum-32-characters

# JWT algorithm and expiration
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# Session secret for server-side sessions
SESSION_SECRET=your-super-secret-session-key-here-minimum-32-characters
SESSION_EXPIRE_HOURS=24

# API keys for internal service communication
API_SECRET_KEY=your-internal-api-secret-key

# ==============================================
# EXTERNAL SERVICES
# ==============================================
# Mapbox access token (for mapping functionality)
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJjbG...

# Mapbox style URL (optional - defaults to streets-v12)
MAPBOX_STYLE_URL=mapbox://styles/mapbox/streets-v12

# Geocoding service API key (if different from Mapbox)
GEOCODING_API_KEY=your-geocoding-api-key

# ==============================================
# THIRD-PARTY INTEGRATIONS (Future)
# ==============================================
# Salesforce CRM integration
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_USERNAME=your-salesforce-username
SALESFORCE_PASSWORD=your-salesforce-password
SALESFORCE_SECURITY_TOKEN=your-salesforce-security-token
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com

# County data source APIs
COUNTY_DATA_API_KEY=your-county-data-api-key
COUNTY_DATA_BASE_URL=https://api.county-data-provider.com

# ==============================================
# API CONFIGURATION
# ==============================================
# Backend API base URL
API_BASE_URL=http://localhost:8000
API_VERSION=v1
API_TIMEOUT=30000

# CORS origins (comma-separated list for development)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# ==============================================
# LOGGING & MONITORING
# ==============================================
# Log configuration
LOG_LEVEL=INFO
LOG_FORMAT=structured
LOG_FILE=logs/application.log

# Error tracking (e.g., Sentry)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# Application Performance Monitoring
APM_SERVICE_NAME=primer-seek-property
APM_ENVIRONMENT=development

# ==============================================
# FILE STORAGE & UPLOADS
# ==============================================
# Local file storage path
STORAGE_PATH=./storage

# File upload limits
UPLOAD_MAX_SIZE=100MB
ALLOWED_FILE_TYPES=csv,xlsx,json,zip

# Supabase Storage bucket (for file uploads)
SUPABASE_STORAGE_BUCKET=property-data

# ==============================================
# DEVELOPMENT SETTINGS
# ==============================================
# Development features
DEBUG_MODE=true
HOT_RELOAD=true
AUTO_RELOAD=true
ENABLE_PROFILING=true
ENABLE_METRICS=true

# Frontend development server
VITE_PORT=5173
VITE_HOST=localhost

# Backend development server
UVICORN_PORT=8000
UVICORN_HOST=0.0.0.0
UVICORN_RELOAD=true

# ==============================================
# TESTING CONFIGURATION
# ==============================================
# Test-specific settings
PYTEST_DISABLE_PLUGIN_AUTOLOAD=1
TEST_LOG_LEVEL=WARNING
TEST_PARALLEL=true

# E2E testing configuration
E2E_BASE_URL=http://localhost:3000
E2E_HEADLESS=true
E2E_BROWSER=chromium

# ==============================================
# PERFORMANCE & CACHING
# ==============================================
# Cache TTL settings (in seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=3600
CACHE_TTL_LONG=86400

# Database connection pooling
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Query timeout settings
DB_QUERY_TIMEOUT=30
API_REQUEST_TIMEOUT=10

# ==============================================
# FEATURE FLAGS
# ==============================================
# Feature toggles for development
FEATURE_MAP_CLUSTERING=true
FEATURE_REAL_TIME_UPDATES=true
FEATURE_BULK_OPERATIONS=true
FEATURE_ADVANCED_ANALYTICS=false

# ==============================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# ==============================================
# These values change based on environment (development/staging/production)

# Development environment
# NODE_ENV=development
# LOG_LEVEL=DEBUG
# DEBUG_MODE=true

# Staging environment
# NODE_ENV=staging
# LOG_LEVEL=INFO
# DEBUG_MODE=false

# Production environment
# NODE_ENV=production
# LOG_LEVEL=WARNING
# DEBUG_MODE=false
# ENABLE_PROFILING=false

# ==============================================
# USAGE INSTRUCTIONS
# ==============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in actual values for your environment
# 3. Never commit .env files to version control
# 4. Use different .env files for different environments
# 5. Validate required variables are set before starting services
#
# Required for basic functionality:
# - SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
# - DATABASE_URL, REDIS_URL
# - JWT_SECRET, SESSION_SECRET
# - MAPBOX_ACCESS_TOKEN
#
# Optional but recommended:
# - SENTRY_DSN (error tracking)
# - All logging and monitoring variables
# - Performance and caching settings
