# Primer Seek Property - Environment Configuration Example
# Copy to .env and configure for your environment

# Application Settings
APP_NAME="Primer Seek Property API"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=development  # development, staging, production
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Database Settings (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.xxx.supabase.co:5432/postgres
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_TIMEOUT=30

# Redis Settings - Single Instance (Development/Staging)
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_RETRY_ON_TIMEOUT=true
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Redis Cluster Settings (Production)
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES=["redis://node1.cluster:6379", "redis://node2.cluster:6379", "redis://node3.cluster:6379"]
REDIS_CLUSTER_SKIP_FULL_COVERAGE_CHECK=false

# Cache TTL Settings (in seconds)
CACHE_TTL_SESSION=1800                    # 30 minutes - User sessions
CACHE_TTL_COMPLIANCE_SHORT=300           # 5 minutes - Dynamic compliance data
CACHE_TTL_COMPLIANCE_LONG=3600           # 1 hour - Stable compliance metrics
CACHE_TTL_FOIA_PROCESSING=86400          # 24 hours - FOIA processing results
CACHE_TTL_PROPERTY_LOOKUP=7200           # 2 hours - Property address lookups
CACHE_TTL_TIER_CLASSIFICATION=21600      # 6 hours - Tier classification results

# Cache Performance Settings
CACHE_WARMING_ENABLED=true
CACHE_WARMING_BATCH_SIZE=100
PROPERTY_LOOKUP_MAX_RESPONSE_TIME_MS=500  # Sub-500ms requirement

# Authentication Settings
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Supabase Settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# External API Settings
MAPBOX_ACCESS_TOKEN=your-mapbox-token

# Data Processing Settings
MAX_IMPORT_BATCH_SIZE=1000
IMPORT_RETRY_ATTEMPTS=3
IMPORT_RETRY_DELAY=5

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "https://yourdomain.com"]

# Production Redis Cluster Configuration Example
# For production deployment, configure Redis cluster with:
# - At least 3 master nodes for high availability
# - Each master should have 1+ replica nodes
# - Use Redis Sentinel for automatic failover
# - Configure Redis memory policies and persistence

# Example Production Redis Cluster Setup:
# REDIS_CLUSTER_ENABLED=true
# REDIS_CLUSTER_NODES=[
#   "redis://redis-master-1.internal:6379",
#   "redis://redis-master-2.internal:6379",
#   "redis://redis-master-3.internal:6379"
# ]
# REDIS_MAX_CONNECTIONS=100
# REDIS_SOCKET_TIMEOUT=3
# REDIS_SOCKET_CONNECT_TIMEOUT=3

# Microschool-Specific Settings
# These TTL values are optimized for microschool compliance workflows:
# - Short TTL for dynamic compliance data that changes frequently
# - Long TTL for stable zoning and regulatory data
# - Very fast property lookup for interactive mapping (<500ms)
# - Extended FOIA processing cache to avoid re-processing large files
