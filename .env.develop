# ==============================================
# DEVELOPMENT SETTINGS
# ==============================================
# Development features
DEBUG_MODE=true
HOT_RELOAD=true
AUTO_RELOAD=true
ENABLE_PROFILING=true
ENABLE_METRICS=true

# Frontend development server
VITE_PORT=5173
