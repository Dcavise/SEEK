# Query timeout settings
DB_QUERY_TIMEOUT=30
API_REQUEST_TIMEOUT=10

# ==============================================
# MICROSCHOOL COMPLIANCE SETTINGS
# ==============================================
# Compliance scoring configuration
COMPLIANCE_CONFIDENCE_THRESHOLD=70
MANUAL_REVIEW_THRESHOLD=50
AUTO_TIER_CLASSIFICATION=true

# FOIA data processing settings
FOIA_IMPORT_BATCH_SIZE=1000
FOIA_RETRY_ATTEMPTS=3
FOIA_TIMEOUT_SECONDS=300

# Property intelligence settings
PROPERTY_MATCH_CONFIDENCE_THRESHOLD=80
ADDRESS_FUZZY_MATCH_ENABLED=true
OWNER_INTELLIGENCE_ENABLED=true

# ==============================================
# FEATURE FLAGS
# ==============================================
# Feature toggles for development
FEATURE_MAP_CLUSTERING=true
FEATURE_REAL_TIME_UPDATES=true
FEATURE_BULK_OPERATIONS=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_COMPLIANCE_SCORING=true
FEATURE_FOIA_INTEGRATION=true
FEATURE_TIER_CLASSIFICATION=true
FEATURE_OWNER_INTELLIGENCE=true

